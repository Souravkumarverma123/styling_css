{
  "name": "pendora-css",
  "version": "1.0.0",
  "description": "A zero-build, utility-first CSS engine — like Tailwind but at runtime. Supports hover/focus variants, responsive breakpoints, dark mode, arbitrary values, full Tailwind color palette, and unique tea colors.",
  "type": "module",
  "main": "dist/pendora-css.cjs.js",
  "module": "dist/pendora-css.esm.js",
  "unpkg": "dist/pendora-css.min.js",
  "jsdelivr": "dist/pendora-css.min.js",
  "types": "src/types.d.ts",
  "exports": {
    ".": {
      "import": "./dist/pendora-css.esm.js",
      "require": "./dist/pendora-css.cjs.js",
      "default": "./dist/pendora-css.cjs.js"
    },
    "./dist/pendora-css.min.js": {
      "import": "./dist/pendora-css.min.js",
      "default": "./dist/pendora-css.min.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "keywords": [
    "css",
    "utility-first",
    "tailwind",
    "runtime-css",
    "pendora",
    "zero-build",
    "design-system",
    "utility-css"
  ],
  "author": "Sourav Kumar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/souravkumdev/pendora-css.git"
  },
  "bugs": {
    "url": "https://github.com/souravkumdev/pendora-css/issues"
  },
  "homepage": "https://github.com/souravkumdev/pendora-css#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "dev": "node --input-type=module -e \"import { initChai } from './src/index.js'; console.log('initChai type:', typeof initChai);\"",
    "build": "node build.js",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "rollup": "^4.20.0",
    "rollup-plugin-terser": "^7.0.2",
    "terser": "^5.32.0"
  }
}
